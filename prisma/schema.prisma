generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum VehicleStatus {
  ACTIVE
  IN_MAINTENANCE
  OUT_OF_SERVICE
}

enum MaintenanceStatus {
  DONE
  UPCOMING
  OVERDUE
}

enum MaintenanceCategory {
  PREVENTIVE
  CORRECTIVE
}

model Vehicle {
  id              String          @id @default(uuid())
  code            String          @unique
  type            String
  brand           String?
  model           String?
  year            Int?
  plate           String?
  serialNumber    String?
  mileage         Int             @default(0)
  engineHours     Int             @default(0)
  status          VehicleStatus   @default(ACTIVE)
  notes           String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  maintenances    Maintenance[]
}

model Provider {
  id              String          @id @default(uuid())
  name            String
  contactName     String?
  email           String?
  phone           String?
  services        String?
  notes           String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  maintenances    Maintenance[]
}

model Maintenance {
  id                    String              @id @default(uuid())
  vehicleId             String
  providerId            String?
  title                 String
  description           String?
  performedAt           DateTime
  cost                  Decimal?            @db.Decimal(10, 2)

  currentMileage        Int?
  currentEngineHours    Int?

  nextDueDate           DateTime?
  nextDueMileage        Int?
  nextDueEngineHours    Int?

  isDone                Boolean             @default(false)
  category              MaintenanceCategory @default(PREVENTIVE)

  notifyDaysBefore      Int                 @default(15)
  notifiedAt            DateTime?

  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt

  vehicle               Vehicle             @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  provider              Provider?           @relation(fields: [providerId], references: [id], onDelete: SetNull)

  @@index([vehicleId])
  @@index([providerId])
  @@index([nextDueDate])
}